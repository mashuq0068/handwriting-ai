# --- Server ---
PORT=4000
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:8080

# --- Postgres ---
# Either set DATABASE_URL, or the individual PG* vars below.
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/hand_db
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=hand_db

# --- Auth / JWT ---
# Use long random strings in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
# Access token lifetime (short) and refresh token lifetime (long)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Optional: single-photo handwriting mode (vision) ---
# A one-time vision call per font locates/labels letters in an uploaded photo.
# Anthropic is primary; Gemini (free tier) is the automatic fallback on any Anthropic error.
# Set either (or both); leave both blank to disable photo mode (template mode is fully offline).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Free fallback #1 — get a key at https://aistudio.google.com ("Get API key", no card).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Free fallback #2 — ANY OpenAI-compatible vision API (tried after Anthropic + Gemini).
# Fill all three with one provider. Examples:
#   Groq:        BASE=https://api.groq.com/openai/v1            MODEL=meta-llama/llama-4-scout-17b-16e-instruct
#   OpenRouter:  BASE=https://openrouter.ai/api/v1              MODEL=meta-llama/llama-3.2-11b-vision-instruct:free
#   GitHub:      BASE=https://models.inference.ai.azure.com     MODEL=gpt-4o   (key = GitHub PAT)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=
