# --- Server ---
PORT=4000
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:8080

# --- Postgres ---
# Either set DATABASE_URL, or the individual PG* vars below.
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/hand_db
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=hand_db

# --- Auth / JWT ---
# Use long random strings in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
# Access token lifetime (short) and refresh token lifetime (long)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- AI (single-photo) mode — two providers, pick per-request in the UI ---
# Claude (Anthropic): VISION only — reads an uploaded sample and locates letters.
#   Cannot generate images. Set ANTHROPIC_API_KEY to enable.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# GPT (OpenAI): VISION (gpt-4o) + IMAGE GENERATION (gpt-image-1) — can clone your
#   whole alphabet into a clean sheet. Set OPENAI_API_KEY to enable.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# (Template/Manual mode needs no keys — it's fully offline.)
